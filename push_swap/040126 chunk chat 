Data assumptions
typedef struct s_stack
{
    int *arr;
    int size;
} t_stack;
Utilities
Find index of max in B
int find_max_index(t_stack *b)
{
    int i = 0;
    int max_i = 0;

    while (i < b->size)
    {
        if (b->arr[i] > b->arr[max_i])
            max_i = i;
        i++;
    }
    return max_i;
}
Smart rotate to top
void	move_max_top(t_stack *b)
{
    int idx = find_max_index(b);

    if (idx <= b->size / 2)
    {
        while (idx-- > 0)
            rb(b);
    }
    else
    {
        int r = b->size - idx;
        while (r-- > 0)
            rrb(b);
    }
}
Push chunk A → B
void	push_chunk(t_stack *a, t_stack *b, int min, int max)
{
    int mid = (min + max) / 2;
    int i = 0;
    int total = a->size;

    while (i < total)
    {
        int x = a->arr[0];

        if (x >= min && x <= max)
        {
            pb(a, b);

            if (x <= mid)
                rb(b);  // send lower half down
        }
        else
            ra(a);      // skip

        i++;
    }
}

✔ Important:

We iterate exactly total times
We don’t loop until chunk is empty (avoids infinite rotations)
Push all chunks
void	push_all_chunks(t_stack *a, t_stack *b, int chunk_size)
{
    int min = 0;
    int max = chunk_size - 1;

    while (a->size > 0)
    {
        push_chunk(a, b, min, max);

        min += chunk_size;
        max += chunk_size;

        if (max >= get_max_value(a))
            max = get_max_value(a);
    }
}
Pull back B → A
void	push_back(t_stack *a, t_stack *b)
{
    while (b->size > 0)
    {
        move_max_top(b);
        pa(a, b);
    }
}
